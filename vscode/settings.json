{
  // ===== Theme & Appearance (Catppuccin Macchiato) =====
  "workbench.colorTheme": "Catppuccin Macchiato",
  "workbench.iconTheme": "catppuccin-macchiato",
  "workbench.productIconTheme": "catppuccin-macchiato",

  // ===== Editor Font (FiraCode Nerd Font) =====
  "editor.fontFamily": "FiraCode Nerd Font Mono, Fira Code, Consolas, 'Courier New', monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,

  // ===== Line Numbers (relative like vim) =====
  "editor.lineNumbers": "relative",

  // ===== Cursor & Line Highlighting =====
  "editor.cursorStyle": "block",
  "editor.cursorBlinking": "blink",
  "editor.renderLineHighlight": "all",

  // ===== Indentation (4 spaces, expand tabs) =====
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,

  // ===== No Word Wrap (vim.opt.wrap = false) =====
  "editor.wordWrap": "off",

  // ===== Smart Indent =====
  "editor.autoIndent": "full",

  // ===== Search Settings (hlsearch, incsearch, ignorecase, smartcase) =====
  "editor.find.autoFindInSelection": "never",
  "search.smartCase": true,

  // ===== Sign Column (always show) =====
  "editor.glyphMargin": true,

  // ===== Split Right (vim.o.splitright = true) =====
  "workbench.editor.openSideBySideDirection": "right",

  // ===== Terminal Colors =====
  "terminal.integrated.fontFamily": "FiraCode Nerd Font Mono",

  // ===== Update Time (faster) =====
  "editor.quickSuggestionsDelay": 50,

  // ===== No Mode Display in Status Bar =====
  "vim.showCurrentMode": true,
  "vim.statusBarColorControl": false,

  // ===== Vim Settings (core vim behavior) =====
  "vim.leader": "<space>",
  "vim.useSystemClipboard": true,
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.ignorecase": true,
  "vim.smartcase": true,
  "vim.easymotion": true,
  "vim.surround": true,
  "vim.sneak": false,
  "vim.foldfix": true,
  "vim.highlightedyank.enable": true,
  "vim.highlightedyank.color": "rgba(250, 240, 170, 0.5)",
  "vim.highlightedyank.duration": 200,

  // ===== Vim: Handle Keys =====
  "vim.handleKeys": {
    "<C-a>": false,
    "<C-f>": false,
    "<C-c>": false,
    "<C-v>": false,
    "<C-x>": false,
    "<C-z>": false,
    "<C-y>": false
  },

  // ===== Disable netrw-like behavior =====
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,

  // ===== File Explorer Settings =====
  "explorer.openEditors.visible": 0,
  "explorer.compactFolders": true,

  // ===== Minimap (like scrollbar plugin) =====
  "editor.minimap.enabled": true,
  "editor.minimap.maxColumn": 80,
  "editor.minimap.renderCharacters": false,
  "editor.minimap.scale": 1,

  // ===== Bracket Matching & Auto Pairs =====
  "editor.bracketPairColorization.enabled": true,
  "editor.autoClosingBrackets": "always",
  "editor.autoClosingQuotes": "always",
  "editor.autoSurround": "languageDefined",

  // ===== Format Settings (like conform.nvim) =====
  "editor.formatOnSave": false,
  "editor.formatOnPaste": false,
  "editor.defaultFormatter": null,

  // Language-specific formatters
  "[lua]": {
    "editor.defaultFormatter": "sumneko.lua"
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[c]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "[cpp]": {
    "editor.defaultFormatter": "xaver.clang-format"
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "[go]": {
    "editor.defaultFormatter": "golang.go"
  },

  // ===== IntelliSense & Completion (like nvim-cmp) =====
  "editor.suggestSelection": "first",
  "editor.acceptSuggestionOnEnter": "on",
  "editor.tabCompletion": "on",
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": true
  },
  "editor.parameterHints.enabled": true,
  "editor.inlayHints.enabled": "on",

  // ===== Git Integration (like gitsigns.nvim) =====
  "git.enableSmartCommit": true,
  "git.autofetch": true,
  "scm.diffDecorations": "gutter",
  "git.decorations.enabled": true,
  "gitlens.currentLine.enabled": false,
  "gitlens.hovers.currentLine.over": "line",
  "gitlens.codeLens.enabled": true,

  // ===== Diagnostics (like LSP config) =====
  "problems.showCurrentInStatus": true,
  "editor.renderWhitespace": "none",

  // ===== Treesitter-like Syntax Highlighting =====
  "editor.semanticHighlighting.enabled": true,
  "editor.tokenColorCustomizations": {},

  // ===== Workbench Settings =====
  "workbench.startupEditor": "none",
  "workbench.editor.enablePreview": true,
  "workbench.editor.showTabs": "multiple",
  "workbench.activityBar.location": "default",
  "workbench.sideBar.location": "left",

  // ===== Status Bar (like lualine) =====
  "workbench.statusBar.visible": true,

  // ===== Command Height (cmdheight = 0 equivalent) =====
  "workbench.editor.tabSizing": "fit",

  // ===== File Associations =====
  "files.associations": {
    "*.purs": "purescript"
  },

  // ===== TODO Comments Highlighting =====
  "todo-tree.general.tags": [
    "BUG",
    "HACK",
    "FIXME",
    "TODO",
    "XXX",
    "NOTE",
    "WARN",
    "PERF",
    "TEST"
  ],
  "todo-tree.highlights.defaultHighlight": {
    "icon": "check",
    "type": "text",
    "foreground": "#24273a",
    "background": "#8aadf4",
    "iconColour": "#8aadf4"
  },

  // ===== Editor Rulers =====
  "editor.rulers": [],

  // ===== Files: Auto Save =====
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 1000,

  // ===== Terminal Settings =====
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.defaultProfile.osx": "zsh",

  // ===== Breadcrumbs =====
  "breadcrumbs.enabled": true,

  // ===== Zen Mode (like focus plugins) =====
  "zenMode.hideLineNumbers": false,
  "zenMode.hideTabs": true,
  "zenMode.fullScreen": false,

  // ===== Smooth Scrolling =====
  "editor.smoothScrolling": true,
  "workbench.list.smoothScrolling": true,
  "terminal.integrated.smoothScrolling": true,

  // ===== Cursor Smooth Animation =====
  "editor.cursorSmoothCaretAnimation": "on",

  // ===== Error Lens (like diagnostics) =====
  "errorLens.enabled": true,
  "errorLens.enabledDiagnosticLevels": ["error", "warning"],
  "errorLens.messageEnabled": true
}
